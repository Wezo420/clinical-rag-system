# =============================================================
# Clinical Intelligence RAG System - Environment Variables
# =============================================================

# ----------------------------
# GROQ API (REQUIRED)
# ----------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=mixtral-8x7b-32768
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.1

# ----------------------------
# DATABASE
# ----------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=clinical_rag
POSTGRES_USER=clinical_user
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://clinical_user:change_me_in_production@localhost:5432/clinical_rag

MONGO_URI=mongodb://localhost:27017
MONGO_DB=clinical_rag_docs

# ----------------------------
# REDIS (Rate Limiting + Cache)
# ----------------------------
REDIS_URL=redis://localhost:6379/0

# ----------------------------
# JWT AUTH
# ----------------------------
JWT_SECRET_KEY=super_secret_jwt_key_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ----------------------------
# STORAGE
# ----------------------------
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/uploads
# For S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=clinical-rag-uploads

# ----------------------------
# ML / EMBEDDINGS
# ----------------------------
CLIP_MODEL=openai/clip-vit-base-patch32
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MEDICAL_EMBEDDING_MODEL=microsoft/BiomedNLP-BiomedBERT-base-uncased-abstract
FAISS_INDEX_PATH=./data/faiss_index
FAISS_DIM=768

# ----------------------------
# ML SERVICE
# ----------------------------
ML_SERVICE_URL=http://localhost:8001
ML_SERVICE_TIMEOUT=30

# ----------------------------
# APP CONFIG
# ----------------------------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----------------------------
# RATE LIMITING
# ----------------------------
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_BURST=5

# ----------------------------
# LOGGING
# ----------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ----------------------------
# SECURITY
# ----------------------------
MAX_TEXT_INPUT_LENGTH=5000
MAX_IMAGE_SIZE_MB=10
ENABLE_PROMPT_INJECTION_DETECTION=true
